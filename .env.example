# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3000                     # HTTP port the server listens on

CORS_ORIGINS=http://localhost:3000  # Comma-separated list of allowed origins

# ─── Application branding (used in email templates) ──────────────────────────
APP_NAME=discovery-hub-api          # Identifies the app in PostgreSQL monitoring
PRODUCT_NAME=Discovery Hub          # Product name shown in email subjects
CHURCH_NAME=RCCG Discovery Centre   # Church/org name shown in email templates
CHURCH_ADDRESS=62 Igi Olugbin Street, Bariga. Lagos, Nigeria

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_HOST=
DATABASE_PORT=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_SSL=false            # Set to true to enable SSL with rejectUnauthorized=false
DATABASE_LOGGING=false        # Set to true to log SQL queries

# Connection pool (pg library)
DATABASE_POOL_SIZE=50         # Max connections in the pool (default: 50)
DATABASE_POOL_MIN=10          # Min idle connections kept alive (default: 10)
DATABASE_POOL=transaction     # Pool mode for PgBouncer/Supavisor: transaction | session | statement
DATABASE_POOL_LOG=false       # Log pool statistics (default: false)
DATABASE_DEBUG=false          # Enable query debug logging in development (default: false)

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRY_IN=1h              # e.g. 1h, 15m, 7d

REFRESH_JWT_SECRET=
REFRESH_JWT_EXPIRY_IN=7d

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=false            # true for port 465, false for 587
EMAIL_SERVICE=                # e.g. gmail (optional if HOST/PORT are set)
EMAIL_USER=
EMAIL_PASSWORD=

# ─── Auth / OTP ──────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=900                   # How long a reset OTP stays valid (default: 900 = 15 min)
FORGOT_PASSWORD_MAX_ATTEMPTS=3        # Max OTP requests allowed per rate-limit window (default: 3)
FORGOT_PASSWORD_WINDOW_SECONDS=3600   # Rate-limit window for forgot-password (default: 3600 = 1 hr)
DEVICE_RESET_MAX_ATTEMPTS=3           # Max self-service device-reset OTP requests per window (default: 3)
DEVICE_RESET_WINDOW_SECONDS=86400     # Rate-limit window for device reset (default: 86400 = 24 hr)

# ─── Global rate limiting (applied to every endpoint via ThrottlerGuard) ─────
THROTTLE_TTL_MS=60000        # Sliding window in milliseconds (default: 60000 = 1 min)
THROTTLE_LIMIT=100            # Max requests per window per IP (default: 100)

# ─── Login rate limiting ──────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5                  # Max failed login attempts before lockout (default: 5)
LOGIN_WINDOW_SECONDS=900              # Lockout window duration in seconds (default: 900 = 15 min)

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost           # Redis server hostname
REDIS_PORT=6379               # Redis server port (default: 6379)
REDIS_PASSWORD=               # Redis password (leave blank if no auth)
REDIS_DB=0                    # Redis database index (default: 0)

# ─── Cache TTLs ──────────────────────────────────────────────────────────────
CACHE_TTL_REFERENCE_SECONDS=300       # TTL for infrequently-changing data: departments, venues, event configs (default: 300 = 5 min)
CACHE_TTL_LEADERBOARD_SECONDS=90      # TTL for attendance leaderboard (default: 90 s)

# ─── Birthday wishes ─────────────────────────────────────────────────────────
WISH_DAILY_LIMIT=20           # Max birthday wishes a single user can send per day (default: 20)

# ─── Attendance / check-in ───────────────────────────────────────────────────
ENFORCE_DISTANCE_CHECK=false  # Require workers to be within allowedDistanceInMeters to check in

# ─── Default event config seed (applied on first boot) ───────────────────────
# Offsets are seconds relative to slot startTime (negative = before start)
DEFAULT_EVENT_CONFIG_NAME=
DEFAULT_EVENT_ALLOWED_DISTANCE_IN_METERS=100
WORKER_CHECKIN_START_OFFSET_SECONDS=-1800   # Workers can check in 30 min before start
WORKER_LATE_OFFSET_SECONDS=0               # Workers arriving after startTime are LATE
MEMBER_CHECKIN_START_OFFSET_SECONDS=-900   # Members can check in 15 min before start
CHECKIN_STOP_OFFSET_SECONDS=3600           # Check-in closes 1 hr after start

# ─── Default venue seed (applied on first boot) ───────────────────────────────
DEFAULT_VENUE_NAME=
DEFAULT_VENUE_ADDRESS=
DEFAULT_VENUE_LATITUDE=
DEFAULT_VENUE_LONGITUDE=

# ─── Admin seed (both required for the default admin to be created on boot) ──
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# ─── App URLs (embedded in emails) ───────────────────────────────────────────
LOGIN_URL=
ADMIN_LOGIN_URL=
SUPPORT_FORM_URL=
EXPLAINER_VIDEO_ANDROID_URL=
EXPLAINER_VIDEO_IOS_URL=

# ─── Cloudinary (file uploads for finance attachments / proofs) ───────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── File upload limits ────────────────────────────────────────────────────────
# Global hard ceiling for all file uploads (bytes). Defaults to 5 MB.
# Individual endpoints may enforce a stricter limit on top of this.
MAX_FILE_UPLOAD_BYTES=5242880

# How many days before an uploaded tithe payment proof is purged from Cloudinary
# and deleted from the database. Defaults to 90 if not set.
TITHE_PROOF_EXPIRY_DAYS=90
